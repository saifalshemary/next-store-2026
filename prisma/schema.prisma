// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id           String   @id @default(uuid())
  clerkId      String   @unique
  FirstName    String
  LastName     String
  username     String
  email        String
  profileImage String
  properties   Property[]
  favorite     Favorite[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Property{
  id String   @id @default(uuid())
  name String 
  tagline String
  category String 
  image String
  country String 
  price Int 
  bedrooms Int 
  bathrooms Int
  description String 
  guests Int 
  services String 
  profileId String 
  favorite   Favorite[]
  profile     Profile @relation(fields: [profileId], references: [clerkId],onDelete:Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Favorite{
  id String @id @default(uuid())
  clerkId String 
  profileId String 
  propertyId String   
  profile Profile @relation(fields: [profileId], references: [clerkId],onDelete:Cascade)
  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}